{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dust",
  "version": "0.1.0",
  "identifier": "com.dust.tool",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "dust",
    "category": "DeveloperTool"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCMzM3MzgzRDBCMDZGMgpSV1R5QmdzOU9EZXpDRWMzTHRweHF6enpsdzlxYW1KRmdDVThmY2s4YzNsUVB4RVhzci9Od3daUQo=",
      "endpoints": [
        "https://github.com/jiulou/dust/releases/latest/download/latest.json"
      ]
    }
  }
}
